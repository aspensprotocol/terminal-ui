# Server-side proxy target for /api/* — consumed by next.config.ts
# rewrites(). Browser always talks to /api; this is where Next.js
# forwards server-side. Point at your running envoy (or a direct
# arborter-gRPC-Web gateway) for local dev outside Docker.
ARBORTER_GRPC_URL=http://localhost:8811
NEXT_PUBLIC_SOLANA_RPC_URL=https://api.devnet.solana.com
