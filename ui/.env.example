# Railway Configuration
RAILWAY_DOCKERFILE_PATH=Dockerfile

# Server-side proxy target for the /api/* Next.js rewrite.
# The browser always hits the same-origin /api path; Next.js proxies to
# this URL server-side. In Docker compose, "http://envoy:8811" works
# because envoy is the service name on the internal network.
ARBORTER_GRPC_URL=http://envoy:8811

# (Optional) Override if you need a direct browser-to-gRPC connection
# that bypasses the Next.js /api rewrite entirely (e.g. static hosting).
# NEXT_PUBLIC_GRPC_URL=https://grpc-web.arborter.example.com

# WalletConnect Project ID
# Get one at https://cloud.walletconnect.com
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_project_id_here
