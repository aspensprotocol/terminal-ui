# Railway Configuration
RAILWAY_DOCKERFILE_PATH=Dockerfile

# The /api/* proxy upstream is HARDCODED to "http://envoy:8811" in
# ui/next.config.ts — envoy is always reachable inside the docker swarm
# under that service name. No ARBORTER_GRPC_URL env var is read at
# build time or runtime; this avoids the build-time-baking footgun
# where a local .env.local could ship a dev URL into a prod image.
#
# For local development OR direct browser-to-gRPC connections that
# bypass the /api proxy entirely (e.g. static hosting), set
# NEXT_PUBLIC_GRPC_URL — the SDK consumes that before falling back to
# the same-origin /api path.
# NEXT_PUBLIC_GRPC_URL=http://localhost:8811

# WalletConnect Project ID
# Get one at https://cloud.walletconnect.com
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_project_id_here
