{
  "name": "terminal-ui",
  "version": "0.0.0",
  "private": true,
  "workspaces": [
    "ui",
    "packages/sdk-typescript"
  ],
  "engines": {
    "bun": ">=1.2.0"
  },
  "scripts": {
    "dev": "cd ui && bun run dev",
    "build": "bun run build:sdk && cd ui && bun run build",
    "build:sdk": "cd packages/sdk-typescript && bun run build",
    "format": "prettier --write .",
    "lint": "cd ui && bun run lint",
    "typecheck": "bun run build:sdk && cd ui && bun run typecheck",
    "clean": "rm -rf ui/.next ui/node_modules packages/sdk-typescript/dist packages/sdk-typescript/node_modules node_modules"
  },
  "devDependencies": {
    "prettier": "^3.8.3",
    "typescript": "^5.9.3"
  },
  "overrides": {
    "ajv": "^6.14.0",
    "axios": "^1.13.5",
    "bn.js": "^5.2.3",
    "brace-expansion": "^1.1.13",
    "defu": "^6.1.5",
    "elliptic": "^6.6.1",
    "flatted": "^3.4.0",
    "follow-redirects": "^1.15.12",
    "h3": "^1.15.6",
    "hono": "^4.11.10",
    "lodash": "^4.18.1",
    "lodash-es": "^4.17.24",
    "minimatch": "^3.1.3",
    "picomatch": "^2.3.2",
    "postcss": "^8.5.10",
    "protobufjs": "^7.5.5",
    "socket.io-parser": "^4.2.6",
    "uuid": "^14.0.0",
    "yaml": "^2.8.3"
  }
}
